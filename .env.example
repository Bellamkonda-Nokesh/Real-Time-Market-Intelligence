# =============================================
# SENTIX — Environment Configuration Example
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── PostgreSQL Database ────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sentix_db

# ── News API (free at newsapi.org) ────────────
# Get your free key at: https://newsapi.org/register
# Note: free tier works on localhost only
NEWS_API_KEY=your_newsapi_key_here

# ── App Configuration ──────────────────────────
PORT=5000
NODE_ENV=development

# ── Session Secret (change this in production) ─
SESSION_SECRET=sentix-change-this-in-production
