# =============================================
# LOCAL POSTGRESQL DATABASE CONFIGURATION
# =============================================
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# - Change YOUR_PASSWORD to your actual PostgreSQL password
# - Change YOUR_DB_NAME to the name of your database (e.g., sentiment_db)
# - Username is usually "postgres" by default

DATABASE_URL=postgresql://postgres:admin123@localhost:5432/sentiment_db

# =============================================
# NEWS API KEY (get free key at newsapi.org)
# =============================================
NEWS_API_KEY=1d7d56dd71064834aac332d65bc22803


# =============================================
# APP CONFIGURATION
# =============================================
PORT=5000
NODE_ENV=development
